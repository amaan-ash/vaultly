    <style name="FieldInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:background">@drawable/bg_rounded_edittext</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">#9AA1AC</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="FieldLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Theme.Vaultly" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/vaultly_blue</item>
        <item name="colorPrimaryDark">@color/vaultly_blue_dark</item>
        <item name="colorAccent">@color/vaultly_blue</item>
        <item name="android:statusBarColor">@color/vaultly_blue_dark</item>
        <item name="android:windowBackground">@color/white</item>
    </style>
    <style name="Theme.Vaultly.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.Vaultly.Splash" parent="Theme.Vaultly">
